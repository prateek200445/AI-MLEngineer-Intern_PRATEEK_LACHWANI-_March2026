QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=policy_db

# Provider: openrouter | google | ollama | openai
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_NAME=google/gemma-3-4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Google
GOOGLE_API_KEY=your_google_api_key_here
GENERATIVE_MODEL_NAME=gemini-2.5-flash

# Ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CLI=ollama
OLLAMA_TIMEOUT=60

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# Retrieval confidence
ELIGIBILITY_RAG_CONFIDENCE_THRESHOLD=0.45
POLICY_RAG_CONFIDENCE_THRESHOLD=0.60
ELIGIBILITY_MIN_TOKEN_OVERLAP=1
POLICY_MIN_TOKEN_OVERLAP=2
